# Copy this file to .env and fill in real values. The .env file is gitignored.
#
# These variables are read by:
#   - demo/run_demo.sh (Phase 4): all three are required to run the end-to-end demo.
#   - The arxiv-deep find_reference_code tool (Phase 1): GITHUB_TOKEN to avoid
#     unauthenticated GitHub rate limits when validating GitHub URLs.
#   - ml-intern itself (Phase 3): ANTHROPIC_API_KEY for the agent loop.

# Anthropic API key for the ml-intern agent's Claude calls.
# Provision at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Hugging Face token with write access to the ml-agent-explorers organisation.
# Used by the demo to push the winning fine-tuned checkpoint.
# Provision at: https://huggingface.co/settings/tokens (select "Write" scope).
HF_TOKEN=

# GitHub personal access token with the "public_repo" scope.
# Used by arxiv-deep's find_reference_code tool to validate GitHub URLs against
# the GitHub API without hitting the unauthenticated rate limit (60 req/hour).
# Provision at: https://github.com/settings/tokens (Tokens (classic) -> Generate).
GITHUB_TOKEN=
